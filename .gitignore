# ═══════════════════════════════════════════════════════════════
# 大数据分析课程项目 · .gitignore (Week 14)
# ═══════════════════════════════════════════════════════════════

# ── Python 虚拟环境 ──────────────────────────────────────────
.venv/
env/
venv/
test_env/
*.egg-info/
__pycache__/
*.pyc
*.pyo

# ── IDE 与编辑器缓存 ────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── 大体积数据文件 ──────────────────────────────────────────
# CSV 数据文件
*.csv
# Parquet 数据文件
*.parquet
# 排除小配置文件
!requirements*.csv

# ── 数据库与临时锁文件 ─────────────────────────────────────
*.db
*.db.tmp
*.db.wal
*.duckdb
*.sqlite
*.sqlite3

# ── 模型与预处理管线文件（体积较大）───────────────────────
*.pkl
*.joblib

# ── 日志文件 ───────────────────────────────────────────────
*.log
*.jsonl

# ── 图片输出 ───────────────────────────────────────────────
*.png
*.jpg
*.jpeg

# ── 环境变量与密钥 ─────────────────────────────────────────
.env
exper.env
*.local.env

# ── Jupyter Notebook 输出 ─────────────────────────────────
.ipynb_checkpoints/

# ── PDF 课程材料（体积较大）────────────────────────────────
*.pdf

# ── 临时与杂项文件 ────────────────────────────────────────
tempCodeRunnerFile.py
*.tmp
*.bak
*.swp

# ── 工作树与任务记录 ──────────────────────────────────────
.claude/
